<?xml version="1.0" encoding="utf-8" ?>
<Patch>
	<Operation Class="PatchOperationFindMod">
		<mods><li>A RimWorld of Magic</li></mods>
		<match Class="PatchOperationSequence">
			<operations>
				<li Class="PatchOperationReplace">
					<xpath>Defs/Sandy_Detailed_RPG_Inventory.ItemSlotDef[defName="ItemSlotNeckTMCloak"]/label</xpath>
					<value>
						<label>Túnica</label>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/Sandy_Detailed_RPG_Inventory.ItemSlotDef[defName="ItemSlotNeckTMArtifact"]/label</xpath>
					<value>
						<label>Amuleto(Cuello)</label>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/Sandy_Detailed_RPG_Inventory.ItemSlotDef[defName="ItemSlotArmsTMArtifact"]/label</xpath>
					<value>
						<label>Brazaletes</label>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/Sandy_Detailed_RPG_Inventory.ItemSlotDef[defName="ItemSlotRightHandTMArtifact"]/label</xpath>
					<value>
						<label>Reliquia (Mano derecha)</label>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/Sandy_Detailed_RPG_Inventory.ItemSlotDef[defName="ItemSlotLeftHandTMArtifact"]/label</xpath>
					<value>
						<label>Anillo (Mano izquierda)</label>
					</value>
				</li>
			</operations>
		</match>
	</Operation>
</Patch>